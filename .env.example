# Copy this file to .env and fill in your real values.
# Get these from the Azure Portal -> your Speech service -> "Keys and Endpoint".

AZURE_SPEECH_KEY=your-key-here

# Set EITHER the region OR the full endpoint URL (endpoint takes priority).
AZURE_SPEECH_REGION=germanywestcentral
# AZURE_SPEECH_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# Comma-separated GitHub usernames allowed to use the app (cloud only).
# Leave empty for local development to disable the allowlist.
# Example: ALLOWED_USERS=qing-dai,alice,bob
ALLOWED_USERS=
